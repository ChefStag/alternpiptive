#!/data/data/com.termux/files/usr/bin/bash

PACKAGE=$2
VENV_DIR="$HOME/.alternpiptive/venv"

echo -e "\033[1;36mAnalyzing: $PACKAGE...\033[0m"

# 1. Attempt Native Install
echo "Trying native installation..."
if pkg install -y "python-$PACKAGE" > /dev/null 2>&1; then
    echo -e "\033[0;32mNative install successful!\033[0m"
else
    # 2. Fallback to VENV on failure
    echo -e "\033[0;33mNative package not found. Redirecting to VENV (Isolated)...\033[0m"
    
    [ ! -d "$VENV_DIR" ] && python3 -m venv "$VENV_DIR"
    source "$VENV_DIR/bin/activate"
    
    # Install in venv
    pip install "$PACKAGE"
    echo -e "\033[0;32mSuccessfully installed in isolated VENV!\033[0m"
fi
