#!/data/data/com.termux/files/usr/bin/bash

ACTION=$1
PACKAGE=$2

# A simple list of packages that have official Termux native versions
# Add new ones here as you find them!
NATIVE_PKGS=("numpy" "cryptography" "matplotlib")

is_native() {
    for p in "${NATIVE_PKGS[@]}"; do
        [[ "$1" == "$p" ]] && return 0
    done
    return 1
}

case "$ACTION" in
    install)
        if is_native "$PACKAGE"; then
            echo -e "Installing native package: python-$PACKAGE"
            pkg install -y "python-$PACKAGE"
        else
            echo -e "No native package found for '$PACKAGE'. Routing to VENV..."
            VENV_DIR="$HOME/.alternpiptive/venv"
            [ ! -d "$VENV_DIR" ] && python3 -m venv "$VENV_DIR"
            source "$VENV_DIR/bin/activate"
            pip install "$PACKAGE"
        fi
        ;;
esac
