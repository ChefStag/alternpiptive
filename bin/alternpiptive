#!/data/data/com.termux/files/usr/bin/bash

PACKAGE=$2
VENV_DIR="$HOME/.alternpiptive/venv"

echo -e "\033[1;36mAnalyzing: $PACKAGE...\033[0m"

# 1. Attempt Native Install
# We suppress output so the user doesn't see "E: Unable to locate" 
# unless we absolutely have to.
if pkg install -y "python-$PACKAGE" > /dev/null 2>&1; then
    echo -e "\033[0;32mNative install successful!\033[0m"
else
    # 2. If it failed, we MUST go to the VENV
    echo -e "\033[0;33mNo native package found. Redirecting to VENV (Isolated)...\033[0m"
    
    # Ensure VENV exists
    [ ! -d "$VENV_DIR" ] && python3 -m venv "$VENV_DIR"
    
    # Activate and install
    source "$VENV_DIR/bin/activate"
    pip install "$PACKAGE"
    
    echo -e "\033[0;32mSuccessfully installed in isolated VENV!\033[0m"
fi
