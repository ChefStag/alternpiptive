#!/data/data/com.termux/files/usr/bin/bash

ACTION=$1
PACKAGE=$2

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BOLD='\033[1m'
NC='\033[0m'

# Add this Mapping Table
case "$PACKAGE" in
    requests) PKG_NAME="python-requests" ;;
    *) PKG_NAME="python-$PACKAGE" ;;
esac

case "$ACTION" in
    install)
        echo -e "${BOLD}Analyzing: $PACKAGE (Target: $PKG_NAME)...${NC}"
        
        # Check if the mapped package exists in the repo
        if pkg search "$PKG_NAME" | grep -q "installed"; then
            echo -e "${GREEN}Already installed natively: $PKG_NAME${NC}"
        elif pkg search "$PKG_NAME" > /dev/null 2>&1; then
            echo -e "${GREEN}Found native package. Installing...${NC}"
            pkg install -y "$PKG_NAME"
        else
            echo -e "${RED}Native package $PKG_NAME not found. Routing to VENV...${NC}"
            # ... (rest of your venv logic)
        fi
        ;;
esac
